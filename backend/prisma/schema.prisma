generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum UserRole {
  admin
  user
}

enum UserGender {
  male
  female
}

enum UserStatus {
  register
  login
  logout
  blocked
}

enum RoomType {
  single
  couple
  family
  presidential
}

enum RoomStatus {
  available
  unavailable
  booked
}

enum BookingStatus {
  pending
  cancel
  approved
  rejected
  in_reviews @map("in-reviews")
  completed
}

// ─── Models ─────────────────────────────────────────────

model Users {
  id                      String      @id @default(uuid())
  userName                String      @unique
  fullName                String
  email                   String      @unique
  phone                   String?     @unique
  password                String
  avatar                  String?
  gender                  UserGender?
  dob                     DateTime
  address                 String
  role                    UserRole    @default(user)
  verified                Boolean     @default(false)
  status                  UserStatus  @default(register)
  resetPasswordToken      String?
  resetPasswordExpire     DateTime?
  emailVerificationToken  String?
  emailVerificationExpire DateTime?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @default(now()) @updatedAt

  // Relations
  rooms                   Rooms[]
  bookings                Bookings[]
  reviews                 Reviews[]

  @@map("users")
}

model Rooms {
  id                String      @id @default(uuid())
  room_name         String      @unique
  room_slug         String      @unique
  room_type         RoomType
  room_price        Float
  room_size         Float
  room_capacity     Int
  allow_pets        Boolean     @default(false)
  provide_breakfast Boolean     @default(false)
  featured_room     Boolean     @default(false)
  room_description  String
  extra_facilities  String[]
  room_status       RoomStatus  @default(available)
  created_by_id     String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @default(now()) @updatedAt

  // Relations
  created_by        Users       @relation(fields: [created_by_id], references: [id])
  room_images       RoomImages[]
  bookings          Bookings[]
  reviews           Reviews[]

  @@map("rooms")
}

model RoomImages {
  id        String @id @default(uuid())
  room_id   String
  url       String

  room      Rooms  @relation(fields: [room_id], references: [id], onDelete: Cascade)

  @@map("room_images")
}

model Bookings {
  id              String        @id @default(uuid())
  room_id         String
  booking_dates   DateTime[]
  booking_status  BookingStatus @default(pending)
  booking_by_id   String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now()) @updatedAt

  // Relations
  room            Rooms         @relation(fields: [room_id], references: [id])
  booking_by      Users         @relation(fields: [booking_by_id], references: [id])
  reviews         Reviews?

  @@map("bookings")
}

model Reviews {
  id          String   @id @default(uuid())
  user_id     String
  room_id     String
  booking_id  String   @unique
  rating      Int
  message     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  // Relations
  user        Users    @relation(fields: [user_id], references: [id])
  room        Rooms    @relation(fields: [room_id], references: [id])
  booking     Bookings @relation(fields: [booking_id], references: [id])

  @@map("reviews")
}
